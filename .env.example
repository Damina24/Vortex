# VORTEX AI — Environment Configuration
# Copy this file to .env and fill in your values

# === Database ===
DATABASE_URL="postgresql://vortex:vortex@localhost:5432/vortex_ai?schema=public"

# === Redis ===
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD=""

# === Next Auth ===
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-change-in-production"

# === OAuth Providers ===
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
NEXT_PUBLIC_GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# === AI Service ===
AI_SERVICE_URL="http://localhost:8000"

# === LLM Providers ===
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""

# === Video Generation APIs ===
KLING_API_KEY=""
KLING_API_SECRET=""
RUNWAY_API_KEY=""
WAN_API_KEY=""
HAILUO_API_KEY=""

# === Audio Generation APIs ===
ELEVENLABS_API_KEY=""
SUNO_API_KEY=""

# === Image Generation ===
FLUX_API_KEY=""
STABILITY_API_KEY=""

# === Storage (AWS S3 or compatible) ===
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"
S3_BUCKET="vortex-assets"
S3_PUBLIC_URL="http://localhost:9000/vortex-assets"

# === Stripe (Billing) ===
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# === Platform Publishing APIs ===
META_APP_ID=""
META_APP_SECRET=""
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""
YOUTUBE_CLIENT_ID=""
YOUTUBE_CLIENT_SECRET=""
GOOGLE_ADS_CLIENT_ID=""
GOOGLE_ADS_CLIENT_SECRET=""

# === Email ===
RESEND_API_KEY=""
EMAIL_FROM="noreply@vortex-ai.com"

# === Rate Limiting ===
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# === Feature Flags ===
NEXT_PUBLIC_ENABLE_ANALYTICS="false"
NEXT_PUBLIC_ENABLE_PUBLISHING="false"
NEXT_PUBLIC_ENABLE_TEAMS="false"